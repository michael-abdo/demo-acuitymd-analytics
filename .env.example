# =====================================================
# VVG Template Environment Variables
# =====================================================
# Copy this file to .env for local development
#
# All settings below target local development. Copy the file,
# fill in your values, and run `npm run dev`.
# =====================================================

# Core application settings
NODE_ENV=development

# Application port (default: 3000)
PORT=3000

# Application base path for subdirectory deployment (e.g., /template)
# Leave empty for root deployment (default)
BASE_PATH=
NEXT_PUBLIC_BASE_PATH=

# Project identification
PROJECT_NAME=vvg-template
PROJECT_DISPLAY_NAME=VVG Template
APP_DOMAIN=localhost

# Log level: debug | info | warn | error
LOG_LEVEL=info

# =====================================================
# AUTHENTICATION (Azure AD / NextAuth)
# =====================================================

# NextAuth.js secret - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here-min-32-chars

# NextAuth URL - full URL including basePath
NEXTAUTH_URL=http://localhost:3000

# Azure AD OAuth Application Settings - REQUIRED
# Create your own app in Azure Portal
AZURE_AD_CLIENT_ID=your-application-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret-VALUE
AZURE_AD_TENANT_ID=your-directory-tenant-id

# Admin emails (comma-separated)
ADMIN_EMAILS=admin@example.com

# =====================================================
# DATABASE (MySQL)
# =====================================================

# Full database connection URL (preferred method)
DATABASE_URL=mysql://root:rootpassword@localhost:3306/vvg_template

# Alternative: Individual database settings
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=rootpassword
MYSQL_DATABASE=vvg_template

# =====================================================
# STORAGE (Local or S3)
# =====================================================

# Storage provider: local | s3
STORAGE_PROVIDER=local

# AWS Configuration (required for S3 storage)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# S3 Bucket Configuration (required for S3 storage)
# S3_BUCKET_NAME=your-s3-bucket-name
# S3_FOLDER_PREFIX=dev/

# =====================================================
# EMAIL CONFIGURATION (Optional)
# =====================================================

# Admin notification email
ADMIN_EMAIL=admin@example.com

# =====================================================
# SECURITY SETTINGS
# =====================================================

# Feature flags - all default to OFF for security
FEATURE_DEV_BYPASS=false

# Test Authentication (development/CI only - NEVER enable in production)
# ALLOW_TEST_AUTH=true
# TEST_AUTH_SECRET=your-secure-test-secret
