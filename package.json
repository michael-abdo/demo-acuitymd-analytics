{
  "name": "vvg-template-simple",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "start:exposed": "next start",
    "lint": "next lint && npm run type-check",
    "type-check": "tsc --noEmit",
    "test": "npm run lint",
    "test:errors": "bash scripts/smoke-test-errors.sh",
    "security:check": "bash scripts/security-check.sh",
    "preflight": "bash scripts/preflight-check.sh",
    "setup": "bash scripts/setup.sh",
    "db:setup": "mysql < database/schema.sql",
    "db:reset": "mysql -e 'DROP DATABASE IF EXISTS vvg_template;' && npm run db:setup",
    "queue:worker": "node -r ts-node/register scripts/queue-worker.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.842.0",
    "@aws-sdk/s3-request-presigner": "^3.842.0",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-aspect-ratio": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.1",
    "@radix-ui/react-context-menu": "^2.2.4",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@types/node": "^22.11.5",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^0.2.1",
    "embla-carousel-react": "^8.3.0",
    "lucide-react": "^0.454.0",
    "mysql2": "^3.14.0",
    "next": "^15.5.9",
    "next-auth": "^4.24.13",
    "next-themes": "^0.2.1",
    "nodemailer": "^7.0.12",
    "pino": "^8.16.1",
    "pino-pretty": "^10.2.0",
    "postcss": "^8.4.48",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.0.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.4",
    "vaul": "^0.9.9"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.2.4",
    "ts-node": "^10.9.2"
  }
}
